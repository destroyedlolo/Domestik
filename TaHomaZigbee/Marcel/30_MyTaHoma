# Create a new TaHoma gateway

*TaHoma=MyTaHoma

	# TaHoma's own
	TaHoma_host=gateway-2095-0445-1705.local
	TaHoma_address=192.168.0.30
	TaHoma_port=8443

	# Developer mode token
	TaHoma_token=@/home/laurent/.tahomatoken

	# delay b/w each poll for event
	Sample=5.5

	# Don't verify SSL chain
	DontVerifySSL

	#####
	# Expected events
	#####
	# Notez_bien : directives are prepended with a 
	# 'expect_' in order to avoid confusion with top
	# level ones. Even if the goals are the same.
	**Expect=Ref_CO2

		# Fields to segregate against incoming event
			# Event's name
		expect_Event=DeviceStateChangedEvent

			# Device's
		expect_deviceURL=zigbee://2095-0445-1705/58849/1#3
		
			# state's name
		expect_state=core:CO2ConcentrationState

		# Lua validation user function
		# Arguments :
		# 	raw value
		# 	compensated value
		# expect_Func=ValTProbe

		# Topic to publish to.
		expect_Topic=SensorCalibration/reference/CO2

		# submitted as retained message
#		expect_Retained

		# Start this state disabled
#		expect_Disabled

		# Disable this state if running in simulation mode
#		expect_DoNotSimulate

	**Expect=Ref_Temperature
		expect_Event=DeviceStateChangedEvent
		expect_deviceURL=zigbee://2095-0445-1705/58849/1#1
		expect_state=core:TemperatureState
		expect_Topic=SensorCalibration/reference/Temperature

	**Expect=Ref_Humidity
		expect_Event=DeviceStateChangedEvent
		expect_deviceURL=zigbee://2095-0445-1705/58849/1#2
		expect_state=core:RelativeHumidityState
		expect_Topic=SensorCalibration/reference/RelativeHumidity
