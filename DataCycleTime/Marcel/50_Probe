Needs=mod_1wire

*FFV=Probe Temperature
	# Where the probe is exposed by OWFS
	File=/var/lib/owfs/mnt/26.86B36A020000/temperature
	# Topic to publish to
	Topic=maison/Temperature/Buanderie
	# Calibration offset
	Offset=0.1578439682
	# Add a pop-up description
	desc=DS-2438
	# Don't publish when the probe is not ready
	Safe85
	# Publish immediately
	Immediate

*FFV=Probe Humidity
	File=/var/lib/owfs/mnt/26.86B36A020000/HIH4000/humidity
	Topic=maison/Humidity/Buanderie
	desc=DS-2438
	Safe85
	Immediate
